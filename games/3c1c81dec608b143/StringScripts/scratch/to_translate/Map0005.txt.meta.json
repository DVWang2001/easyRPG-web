    ],
    "items": [
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "聞こえてたよ。タマ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なにがニャ？"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "\\.目がう～んと細くてタレてて\n悪かったね。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ぶほ。\nき、聞こえていたニャ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ア、アレは･･･\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お、男は細目でタレ目が１番だ\nという意味で言ったニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "悪かったな\nクリ目のつり目の男で。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･････人のあげ足をとるニャよ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.「人」ではないではないか。"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "\\.\\S[2]････････････。\n"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "\\.漫才しに来たのか君ら？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "いや、違う。"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "\\.待て。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･････････。"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "どういう理由があるかはわからないが\nここから先に行かせるわけには\nいかないんだ。"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "余計な争いごとはしたくない。\nこのまま帰ってくれ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････\n余計な争いごとをしたくないのは\n私も同じだ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "だが\n\\.悪運だけに頼って生きてきた\n男の命がかかっているのでな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "このまま帰るわけには\nいかぬのだ。"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "\\.\\S[2]悪運だけに頼ってきた男の･･････"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
            "text": "･･････そうか。\n\\.では仕方ないな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "通してくれるのニャ？！"
        },
        {
            "face": "Ｆ真実",
            "marker": "Message",
