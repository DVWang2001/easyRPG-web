    "items": [
        {
            "face": "NONE",
            "marker": "Message",
            "text": "\\.ふっふっふっふふ～ん$a"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.？"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.･･･はニャ$d"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.しまった･･･\n\\.シッポが挟まったニャ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････なんだ？\n\\.誰かいるのか？"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.ありゃ。取れないニャ$e$e$e"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "ニャ～っ"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "シッポが\n罠にかかっちゃったニャ～っ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････シッポ？"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "ふに～っ$e\nふにょ～っ$e"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\S[3]････････････。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "誰か取ってニャ～～～っ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.少し待て。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "こう暗闇では\nそなたがどこにいるかも\nわからぬ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "今、明かりをつける。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャっ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "なんか急に明るく･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]･･･････････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.？　\\.･･･おまえ　誰ニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]･････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[3]･････････\\.タヌキ？　　"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.タヌ･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.タヌキじゃないニャ！　猫ニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]しゃべる猫か･･････\\.化け猫だな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "化け猫で悪かったニャ$n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャ、ニャっ！\n\\.ちっ近寄るニャっ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.シッポが罠に引っかかったと\n言っていたろう。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.罠をはずしてやるから\n向こうを向け。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.余計なお世話ニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お主なんかに頼まなくても\n自分ではずせるニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.ついさっき暗闇で"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]「誰か取ってニャ～～～っ$e」\n\\S[1]と言っていたのが聞こえていたが？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.むぐっ$n\n\\.聞かれてたのニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.おそらく 村の猟師が\n獲物を仕留めるために\n仕掛けた罠だろう。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そこに \n化け猫がかかっているとわかったら\n袋叩きにでも遭いかねぬぞ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.違うニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.この罠は\nお主らみたいな 外から来る\n怪しげな人間をハメるために"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "オイラが自分で仕掛けた罠ニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[3]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.なるほど。\n\\.では、自分が仕掛けた罠に\nハマったのか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "はっ。　"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "自分で自分の仕掛けた\n罠にハマったコトを\nばらしてしまったニャ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.　$d"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･･まあいい。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "後ろを向け。\n罠を外してやる。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そ、そ、そんなことを言って･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "後ろを向いた隙に\nオイラを仕留めようという気ニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.安心しろ。\n私はそんな暇人ではない。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "いやニャ～っ\n誰か助けてニャ～っ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "まわれー･･･右。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "くるっ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ア、アレ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "少し動くな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ふ～\n\\.短い命だったニャ･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.･････････$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.でも、どうせ死ぬなら"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "せめてその前に\nオイラ、鯛の尾頭付きが\n食べたかったニャ･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "はずれたぞ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そうニャ。\n一度、マタタビとかいうものも\n試してみたかったニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････。\nはずれたぞ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.\\S[2]････････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "はニャ？\n生きてるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "当たり前だ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "私に\n化け猫を食らう趣味はない。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.れ、礼は言わないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.かまわぬ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.化け猫に礼を言われても\n嬉しくないしな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "なんか、今の\nムカついたニャ$n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "だ、だいたいお主"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "こんな山奥の洞窟に\n何の用ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "見たトコ、\n\\.男のくせに 女みたいな細腕だし\n\\.化け猫のオイラも助けてくれたし"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "金目当てに 村の連中から\n「妖怪退治」を引き受けて来たワケでは\nなさそうニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.妖怪退治に来たつもりはない。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.こんな洞窟に\n山菜なんて生えてないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.だからといって、誰も\n山菜取りに来たとは言っておらぬ$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "じゃ、何しに来たニャっ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.うむ、実は"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.先月、妖怪にさらわれて\n行方不明になったという\n羽村の姫君を探しに･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･･\nそんな姫、ここにはいないニャ。\n"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.いなくていいのだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.ニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.姫君を探す･･･\\.フリをして\n実は「狐」に会いに来たのでな。\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.狐？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.この洞窟のどこかに\n人の姿をした狐がいるだろう。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.狐の姫さんなら この奥に\n\\S[2]･･･････････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･･････････････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.いないニャ。\n"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.この奥に\\S[2]･････････\n\\.いないのか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･･えーと"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ウソのつけない化け猫だな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.ほ、\\.ほっといてニャ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "まぁ、よい。\n勝手に探すまでだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ま、待つニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.なんだ？　急いでいるのだが。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お主、狐の姫さんに何の用ニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････\\S[1]話があるだけだ。\n\\.用が済めばすぐに 退散する。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.姫さんは誰にも会いたくないと\n言ってるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.だからオイラたちが\nこうやって扉の番をしてるんニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.オイラたち･････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そうか。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.他にも扉の番をしている妖怪たちが\nいるということだな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.そうニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "途中途中にも\n恐ろし～い妖怪がいっぱいいるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "よっぽど腕に自身がなければ\n命がいくつあっても足りないニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "お主がどうなろうと\n知ったことではないが"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "罠を外してもらったことだし\n一応、忠告しておくニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････わかった。\n"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "そなたを見ていると\n恐ろしい妖怪がたくさんいるようには\n思えぬところだが･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.忠告は承っておく。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "よしニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そうと決まれば\nさっさと行こうニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････さっさと、って"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そなたも一緒に行くつもりか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "当たり前ニャ。\nお主が姫さんに何もしないよう\n見張ってるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.それともなんニャ。\nオイラが一緒に行くと\nまずいコトでもあるニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････いや$d"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･ま、\\.タヌキ１匹増えたところで\nどうということもなかろう。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そうと決まれば\nさぁ、行くニャ･･････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[2]･･････って、\\S[1]だから\nタヌキじゃなくって猫ニャって！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "もうなにないニャ。\n顔に似合わず欲張りだニャ、お主。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "その鍵があれば、\nとりあえず、最初の扉は開くニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そこの赤い包みに\n鍵がはいっとるハズニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ココはオイラの部屋ニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "タヌキの部屋に用はない。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "待つニャ。\nそこの赤い包みの中に\n入り口の扉を開ける鍵が入ってるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････って、猫ニャってば！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "さっきの鍵で開くはずニャ。\nえーと、鍵穴　鍵穴･･･と･･････あった。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "開いたようだな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵はオイラの部屋ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "さっきの鍵で開くはずニャ。\nえーと、鍵穴　鍵穴･･･と･･････あった。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "開いたようだな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "アレ？　開かないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･鍵穴があるようだが。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あ、そうだったニャ。\n鍵がないと開かないんだったニャｧ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ココの鍵なら\nさっきの入り口右に行ったところの\nオイラの部屋にあるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そこの赤い包みに\n鍵がはいっとるハズニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ココはオイラの部屋ニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "タヌキの部屋に用はない。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "待つニャ。\nそこの赤い包みの中に\n入り口の扉を開ける鍵が入ってるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････って、タヌキじゃなくて猫ニャ！"
        }
    ]
}