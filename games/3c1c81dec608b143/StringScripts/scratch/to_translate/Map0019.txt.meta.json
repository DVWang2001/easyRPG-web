        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "ちっ･･･\n嫌なこと思い出しちまったぜ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････。"
        },
        {
            "face": "Ｆ鬼",
