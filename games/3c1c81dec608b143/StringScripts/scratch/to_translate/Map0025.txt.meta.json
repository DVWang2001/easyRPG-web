    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.薬草見っけ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "よくいろいろな物が落ちている\n洞窟だな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "がさつな奴ばっかりでニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "穴のあいた風呂敷持って\nあっちこっち移動しとるからニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "　\\.$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.ひとつ\nお主に聞いてもいいニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.なんだ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お主は一体\n誰のために 姫さんに会おうとしてるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.さっきから聞いてると\n誰かのために\n姫さんと会おうとしてるみたいニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[3]････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.私もわからぬ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]きっと会えば･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.それがわかるのではないかと\nそう思ってやって来たのでな･･････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[3]････････････。"
        }
    ]
}