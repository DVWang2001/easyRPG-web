    ],
    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なんニャ。\nいきなり立ち止まって。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.というか、そなたの方が\nここの住人なのだから\n私よりも先に歩いて案内するのが\n普通ではないのか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "オイラ新人で\nあんまり奥まで行ったことないから\nよくわからないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････新人･･･$d\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.それよりお主。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さんが美人だからって\nヘンな気を起こすニャよ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お主、無愛想だが\n『むっつりスケベー』という\nことわざもあることだし\n油断は出来ないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.ことわざか、それ･･･？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･ん？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････！\nなんだ？！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････木の･･･根？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "そなたの仲間か？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "違うニャ。\n「一つ目根」だニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "オイラたちが\nここへ住み込む前から\nここにいる妖怪ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "じ、実物は初めて見たニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]一つ目･･････\n･･････人の目？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･･この辺り一帯は\n昔、戦場だったニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "毎日毎日\n多くの兵士達が死んで\n多くの血を流した場所ニャ･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.その血を吸いながら育った樹木たちの\n変化した姿に違いないと\n言われているニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.聞いたことがある。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.一説には\n死ぬ前に一目家族に会いたいと願った\n兵士達の変わり果てた姿とも･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "いずれにせよ\n２人とも敵だと 思われているようだ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "下がっていろ。ぽん太。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "１人じゃ無理ニャ！\nオイラも加勢するニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････って、\nオイラの名前は『タマ』ニャ！！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ふ～。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.しかし、お主\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "一見、優男みたいなクセして\n結構強いニャ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "･･････ほっほっほ"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "みね打ちだけで\n一つ目を倒すとは\n大した腕前じゃのう。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "ふん。\nなかなか、やるじゃねーか。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "しかもなかなかの美形"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "あれで少々\n無精ヒゲを生やせば\nわしの若い頃そっくりですじゃ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "･･･ジジイ"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "チョット顔がいい奴が現れるとすぐ\n自分に似ていると言うのは やめろ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "ほっほっほ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "のんきに笑ってる場合じゃねーだろ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "あれだけの腕がありゃ\nジジイの１人や２人\n片手でひねり潰されるぞ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "ほっほっほ\n最近ヒマしておりましたでな"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "楽しみですじゃ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.ふん。\n"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.ムリして\nまた、ぎっくり腰になっても\n面倒みてやんねーからな。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "ま、そうならんよう まずは\n少々お手並み拝見といきますかな。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\S[2]そうだな。\nまずは･･････"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.\\S[2]奴に任せるとするか･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "どしたニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････\\.気のせいか？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.どこからか視線を感じたのだが･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "視線？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････いや、気のせいか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.誰もいないし･･･\\.気のせいニャ。\n"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.まだまだこの先\nいろんなのが出てきそうだな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なんニャ。\nいきなり立ち止まって。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.というか、そなたの方が\nここの住人なのだから\n私よりも先に歩いて案内するのが\n普通ではないのか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.オイラ新人で\nあんまり奥まで行ったことないから\nよくわからないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････新人･･･$d\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.それよりお主。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さんが美人だからって\nヘンな気を起こすニャよ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]･････････$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お主、無愛想だが\n『むっつりスケベー』という\nことわざもあることだし\n油断は出来ないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.ことわざか、それ･･･？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･ん？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････！\nなんだ？！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････木の･･･根？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "そなたの仲間か？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "違うニャ。\n「一つ目根」だニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "オイラたちが\nここへ住み込む前から\nここにいる妖怪ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "じ、実物は初めて見たニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]一つ目･･････\n･･････人の目？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･･この辺り一帯は\n昔、戦場だったニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "毎日毎日\n多くの兵士達が死んで\n多くの血を流した場所ニャ･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.その血を吸いながら育った樹木たちの\n変化した姿に違いないと\n言われているニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.聞いたことがある。"
