    "items": [
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.･･･どうした？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "この先に\nオイラたちの仲間の妖怪がおるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･そうか。\n"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ムリに着いてこなくていいぞ\nポチ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "タマ･･････\\.ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "そうじゃなくって\n\\.･･････結構いい奴ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "意外に話がわかる男ニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.うまく事情を話せば\nもしかしたら\n闘わずにすむかもしれないニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "それか 味方になってくれるかも\nしれんニャ"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････そうか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ただ\n目がう～んと細くてタレとるから\nそこだけ気をつけてニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････わかった。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････目が細くてタレていると･･･\n\\.\\S[1]何に気をつけろと？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "細かいことは気にせずに早く行くニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ひょうたん？\n･･････酒か？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "なんで\n酒の入ったひょうたんが\nこんなトコに落ちてるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "さぁ･･･\nここの住人の そなたが知らぬのでは\n私に知りようがないな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.それはそうニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "酒なら\n気付け薬代わりになるかもしれぬ。\n･･･持っていくか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "？？？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "？\nなにをしている。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "はニャ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ツタが首に\n絡まっちゃったみたいニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "とっ\n取れないニャっ$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････お主\n挟まったり 絡まったり\n忙しいな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャ～っ！\nのんきなこと言ってないで\n取ってニャっ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "今　取ってやる。\n少しじっとして･･････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "なにニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "そなたの首に絡まっているのは\nツタではない。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "蛇だ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "蛇？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "････････････････････････\n\\S[2]････････････････････････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ぶニャ～～～～～～っっっっっっっ！！！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ゲホゲホっ$e"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
