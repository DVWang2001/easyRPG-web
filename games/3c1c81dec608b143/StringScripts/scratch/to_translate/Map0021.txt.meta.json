    "items": [
        {
            "face": "NONE",
            "marker": "Message",
            "text": "早く行け。\n夜が明けるぞ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "息子のことを忘れたことは\n一度もなかったが"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "わからぬはずよ･･････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]あんなに大きくなっていたのだから\n･････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "待て\n違うのだ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]春信は･･････\\S[1]父は\nそんなことになっているとは\n知らなかったのだ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.知らなかったはずはない。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "あの時･･･\n私が狐であることに\n気づいた者がいたとしたなら"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "それは\n\\S[2]あの男しかいなかったのだ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "違う！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "そなたが狐であることを\n周囲に漏らしてしまったのは"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････私なのだ･･････。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.･･････？！"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "　　　　　\\S[2]\\C[17]そう･･････　　　\n　　　　　･････････私なのだ･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]\\.あの日私は･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]どうしても眠れず、\nこっそり寝床を離れて\nそなたの部屋へ向かった"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]だが･･･"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]満月の月明かりに照らされ\nそなたの部屋にいたのは"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\S[2]\\C[17]一匹の狐だった･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]５つになったばかりだった\nあの時の私に"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]その狐が\nそなたであろうなどということは\n想像もできなかったのだ･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]･･･だから"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]狐がいると･･･\n"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\S[2]\\C[17]母の部屋に狐がいると\n\\.祖父に伝えてしまった･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "祖父らが\nそなたを追い払ったと聞いたときの\n父の顔は今でも忘れられぬ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "その後も\nそなたを探し続けていたが\n結局見つからずじまいだった。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "だから･････････\n恨むべき相手は父ではなく･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]この私なのだ･･････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[2]･･････\nお、親子だったのニャ･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "通りで２人揃って\n人の名前覚えが悪いと･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "２０年近く経った今やっと、\n狐などの妖怪が\nこの辺りの洞窟に住み着いているという\n情報を得て"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "うまい具合に･･･と言っては\n申し訳ないが･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "今の私の仕え先である\n羽村の一の姫が行方不明になるという\n騒ぎがあって"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.その姫君探索にかこつけて\n城を抜けてきたのだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.しかし 親子というのはすごいものだな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "５歳の頃の記憶など\n定かでないのに"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そなたの姿を見たとき\n･･･一瞬で母だとわかった。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]･･･････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "昔と変わらぬ姿のようだが\n\\.少し若作り過ぎぬか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･････････$d"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[4]････････････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.\\S[4]･････････ふ"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.\\.母に向かって\n若作りが過ぎるとは\n･･････全く親の育て方が伺えるな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.全く"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "その親は\n大雑把で不器用で女と酒が好きで\nどうしようもない男で 私も苦労したが"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そなたが再び\n自分の目の前に現れることを\n\\.真に願っている･･･"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[8]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.あまり時間がないのだ。\n会いに行ってやってくれ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.母上。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[8]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.\\.姫さん。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[8]･････････。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]････････････\n羽村の城へ行けば･･････\n\\.会えるのだな？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.姫さん！"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "日のあるときには出歩けぬ。\n今宵参ろう･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･････････わかった。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.ならば、\n\\.そなたが来るまでの間は\n首を絞めてでも 父を生かしておくと\n約束する。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.首絞めたら\n死んでしまうニャ･･･$d"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "その前に\nこの姿でいるのは疲れるのでな\n\\.一度本来の姿に戻らねばならぬ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "だが\nせめてそなたの前では\n人の姿であり続けたい。"
        },
        {
            "face": "Ｆ狐姫",
