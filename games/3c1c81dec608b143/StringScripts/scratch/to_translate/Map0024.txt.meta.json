    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あっ、そうニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "この上に、おジジがおるからニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.おジジ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "次の扉を守ってる\nオイラたちの仲間の妖怪ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "もしまた\n闘うことになっても\nおジジは歳いってるから\n手加減してやってニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "それは･･･\n\\.扉を守っている意味があるのか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.\\S[2]･････････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "　\\.\\.\\.$d"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "　\\.\\.\\.$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.\\.ま、あんまり深く考えないでニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･･おにぎり見っけ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.何でこんなトコロに？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "うーん。\n誰かココで夕飯食べたんだニャ。\nきっと。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "持っていこ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]ところで･･････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.ひとつ聞いてもよいか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なんニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.なぜ そなたは\n「狐」のことを「姫さん」と\n呼んでいるのだ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.ん～"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.この洞窟を取り仕切っているから\nってのもあるかもしれんが･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お姫さんみたいに\nキレイだから･･･ってのも\nあるかもしれんニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.他の者たちも\nみんなそう呼んどるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.\\S[2]･････････そうか。"
        }
    ]
}