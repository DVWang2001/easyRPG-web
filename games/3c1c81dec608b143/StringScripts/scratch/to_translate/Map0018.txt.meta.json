    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "味方になってくれなかったニャ･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "それ以上もってったらドロボーニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "では、そなたもあさるな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵　鍵と･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あったニャ。\n\\.･･････ニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "どうした。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "薬草がいっぱい入ってるニャ。\nちょこっともらっていくかニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.･･･そうだな。\n出世払いということで\n２つ３つ頂戴するか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･･止めると思ったが\n\\.お主　意外とシュールじゃニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ま、いいニャ。\n鍵と一緒に　\n薬草４つだけもらっていくニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "開いたニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵は 紫の包みの中だと思うニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャ～っ$e"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･･は、はニャ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "い、今のは何だったニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･･随分とリアルな幻影だな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.この男が抱えていた過去が\n妖気と一緒に 飛散したのだろう。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "過去が飛散？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "なんで飛散したニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.さぁな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ただ･･････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.この男の姿は\nもう 普通の人の姿に戻ったようだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.あ。\\.そういえば\nマコトの背中にあった\n黒い羽がなくなってるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.さっきの幻影のカラスと\nマコトの黒い羽と\nなんか関わりがあったんかいニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そうかもしれぬ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "カラスにとり憑かれていたニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "カラスというか\nカラスが持っていた闇というか･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.心の空白に\n闇がとりつくことは よくあることだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[2]闇･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.マコトは優しい奴だからニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ホントはお主のことだって\n通してやりたかったんニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "だからオイラに\nお主の味方をしろって･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････わかっている。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[3]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.先･･････行くかニャ？"
        }
    ]
}