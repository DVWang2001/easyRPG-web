    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ナンマイダブニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "死んではおらぬて。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵も酒も持ったニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "おジジには悪いが\n勝手に鍵持ってくニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "えーと"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あったニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "はニャ？\n･･････コレはなにニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ほう、酒か。\n気付け薬代わりになるな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････\nもらってけと言っているように\n聞こえるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ふむ。延命酒『剣豪』か。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "こんな歳で\nこんな強い酒を飲んでいたとは意外だな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "聞いとらんニャ　お主･･･。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[2]････････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なんか切なくなってきたニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.前におジジのこと\nマコトから聞いたことがあるニャ。\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.枯れ木と一緒に 埋まっているところを\n姫さんが見つけて 拾ってきたって。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･･では\n今の「狐」というのは･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さんのことニャ。\\.きっと。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.しかし人の心とは そんなに\nとり憑き易いものなのかニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そうかもしれぬな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵がないと開かないニャ。\nそこら辺に緑の包みがないニャ？"
        }
    ]
}