    ],
    "items": [
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\S[2]･･････よぉ、来たな。\n"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "　\\.！"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.オイ、タマ。\n"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\S[3]誰がヘクション大魔王だって？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "オ、\\.オイラが言ったんじゃないニャ～$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[3]････････････。\n"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.なんだその顔は。\n"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.ナマで鬼を見るのは初めてか？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････鬼･･･"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "おめーもおめーだ　タマ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "なに　そんなヤツの手助けしに\nついて回ってやがる。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "てっ手助けじゃないニャ。\n見張ってるんニャ$d"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "そうは見えねーよ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･････････。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.･･･ま、\\.いーか。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.さっさと始めて\n\\.さっさと終わらせるとするか。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.待て、私は"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "何も聞きたかねぇよ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.おめーは ここを通りたい。\n俺は おまえを通したくねぇ･･･"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "闘う理由はあるわけだ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "遠慮なくかかってきな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････問答無用か。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "それから、\nそっちが２人がかりなら\nこっちも人数増やさせてもらうぜ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャニャっ！"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "出でよ\n左童破天！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.よし。\n鬼の懐を探ってみるか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････ないニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.懐にないとすると\\S[2]･･････"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "･･･どこ触ってやがる\nこのスケベ野郎！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あっ。\n生きてるニャ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.ったりめーだ。\n俺を誰だと思って･･････っ痛てて"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.気色悪いのはお互い様だ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.胸元を探られるのが嫌なら\n鍵を渡せ。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\S[2]･･････ちっ"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.言いたいこと言いやがる。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.\\S[2]･･････だが"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.おめー、\n\\.あの鬼火の技は どこで覚えやがった。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････さぁ\n\\.どこでだったかな。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\.ちぇ。\n愛想のねー奴だぜ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.物心ついたときには\n使えるようになっていたからな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]どこで･･･\\S[1]と言われても\nわからぬだけだ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ま、\\.これのおかげで　\n子供の頃はよく、\n鬼の子と言われたものだが。"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "･･････"
        },
        {
            "face": "Ｆ鬼",
            "marker": "Message",
            "text": "\\S[2]･･････\\.鬼の･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.どうしたニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "強い･･･妖気のようなものを感じる。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "さっきの２人とは\n少々ケタの違う妖怪がいそうだな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "それはそうニャ。\nここの扉を守ってるのは おそろし～い･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "お･･････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "お？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "へっくしょん$e"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "はニャ～、風邪ひいたかニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･\nへっくしょん大魔王か。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "へ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ぜーぜー･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････良かった\nオイラ生きてるニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.これでまた\nアノ、変な光がブニョ～っと･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\S[2]･･････････････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････アレ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "今回は\n何にも起きないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "鬼というのは\n人の心が生み出したもの･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "自らが心を開かねば\nその変化がとかれることは\nあるまい。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\s[4]･･････心･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "先へ進むぞ。\nこのままでは夜が明けてしまいそうだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･･わかったニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.さて･･･扉の鍵は･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "鬼本人の懐を探ってみるか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "やっぱ\n開かないニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "け飛ばしてみるか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･････。\n\\.お主、顔と似合わないことを\nするニャって。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "･･･開かぬな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "本人が持っているかもしれぬな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "やっぱり鍵がないと\n開かないんだニャ･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "しかし、そんな包みらしきものは\n見あたらぬが。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵を探すニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "てめー･･･草次郎･･･！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "なにしに来やがった！！"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "なにしに来たとは\n随分なご挨拶だな、小吉。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "せっかく\n雪乃の幼なじみのよしみで\n線香の一本もあげに来てやったって\nいうのにな。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "なんだと･･･？！"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "誰のせいでこんなことになったと\n思ってるんだ！"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "草次郎、てめー\n雪乃になにしやがった！！"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "\\.\\.なんにもしてねーよ。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "\\.しようとしたら　あの女\n\\.勝手に舌噛んじまいやがったんだからな。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "小吉の借金をまけてくれと\n泣いて頼むから"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "\\.話によっては\nまけてやってもいいと言ってやったのに\n恩知らずな奴だぜ。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.･･････\\.てめーは"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.てめーは･･･人間じゃねぇ。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "てめーは･･･鬼だ！"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "･･････。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "\\.\\S[3]鬼で結構。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "\\.だが悪いのは\n借金つくっておめーを置いて家を出た\nおめーの親父だ。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "\\.俺を恨むのは\nお門違いって奴だぜ、\\.小吉。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "草次郎の親父も嫌な金貸しだったが\nあいつは輪をかけてひどい奴だな。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "本当だよ。\nあいつは本当に鬼だよ。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "雪乃は\nあいつが殺したようなもんさ。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "違いねぇ。\n小吉もかわいそうにな。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]なんとでも言えばいい･･･"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]なにを言われようとも"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]俺は生まれてこの方\n　　　　　\\.こういう生き方しか\n　　　　　教わってこなかったのだから\n　　　　　･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]親父は\n困っている奴らを助けるために\n金貸しを始めた。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]でも、こんな時世、\n借りた金をまともに返せる奴なんて\nほとんどいやしねぇ。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]感謝されるのは\n初めだけで"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]ほとんどの奴らは\n金の取り立てに行けば\n揃いも揃って　嫌な顔をしやがる\n･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]だから親父は\n鬼になって取り立てを始めた･･･\nそして"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]そんな親父を見るのが嫌で\n家を出た兄貴に代わって　俺が"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]\\S[2]鬼の後を継いだ･･････"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]あれから４年も経つ。\nいい加減　鬼と言われるのにも\n慣れてきた。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[3]だが 雪乃･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\.\\S[2]\\C[17]少なくとも\\S[1]\n　　　　　\\S[2]おまえにだけは･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]\\S[2]･････････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]草ちゃん･･･\n　　　　　\\.またお父さんと喧嘩したの？"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]･･･殴られたんだ？"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]\\S[2]･････････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]\\.親父は俺が嫌いなんだ"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]なに言ってるの？\n　　　　　\\.そんなわけないじゃない"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]だいたい、兄貴には\n　　　　　「森太郎」なんて名前つけて、\n　　　　　俺には「草次郎」だ"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]草だぜ、草！"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]･･･あのね"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]草ちゃんのお父さん、\n　　　　　\\.森太郎お兄ちゃんには大きく\n　　　　　草ちゃんには強く育って欲しい\n　　　　　って、そう言ってたよ。"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]草って\n　　　　　踏まれても踏まれても\n　　　　　起きあがる･･･\n　　　　　強い生き物だからって"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]\\S[2]･････････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]あたしは草ちゃんの名前\n　　　　　\\.好きだなぁ"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]\\S[2]･････････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]･･････ね\n　　　　　\\.一緒に謝ってあげるから\n　　　　　家に帰ろう？"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[19]\\S[2]ね？　草ちゃん･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[3]雪乃･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]おまえが\n　　　　　\\.小吉の借金をまけてくれと\n　　　　　俺に相談を持ちかけてきたとき"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]俺がおまえに惚れていると\n　　　　　言ったら･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]なぜ\n　　　　　\\.あんなに怯えた目をした？"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]幼なじみで\n　　　　　子供の頃からの仲良しだった\n　　　　　そんなおまえから見ても"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]俺は\n　　　　　鬼に見えたのか･･････？"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]おまえがあんな顔をしなければ\n　　　　　･･････\n　　　　　俺に怯えたりしなければ･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]俺はおまえに\n　　　　　あんなことをするつもりは\n　　　　　なかったんだ･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[3]俺は本当に\n"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　\\C[17]\\S[3]おまえが好きだったのだから･･･"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]雪乃･･････"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]俺が本当に\n　　　　　おまえに何かすると思ったか？"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]小吉と一緒になると言って\n　　　　　喜んでいたおまえの幸せを"
        },
        {
            "face": "Ｆ草次郎",
            "marker": "Message",
            "text": "　　　　　\\C[17]\\S[2]俺が壊したいと思っていると\n　　　　　･･････\n　　　　　本当に思ったのか･･････？"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]いっそ"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]本物の鬼になれればいい。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\C[17]\\S[2]そうすれば\n罪悪感のかけらもなく\n俺は生きていけるのだから。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
