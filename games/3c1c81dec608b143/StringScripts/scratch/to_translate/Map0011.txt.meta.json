    ],
    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さんっ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]･････････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.ほう。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.･･･そなた\nミケをを人質に ここまで来るとは\nなかなかやるな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.姫さん\n人質になったわけじゃないニャ\n･････････というか"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.その前に\n「ミケ」じゃなくて「タマ」･･･\\.ニャ$d"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･･オイラの名前\nそんなに覚えにくいニャ？"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.ここには誰も連れてくるなと\n言っておいたはずだが。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.ごめんニャ。\n"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "でも、こ奴\nなんかワケありみたいニャ。\n姫さんに話がしたいだけって\n言うから･･･"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]そなた･･････\n\\.\\S[1]相馬春信を 知っているな。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.\\S[2]相馬･･････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "･･････\nそなた、なぜ相馬のことを･･････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\.相馬はもう、永くない。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.会いに行ってやってほしい。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]･････････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.\\.断る。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.それは･･･"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.理由など\nおまえら人間に話したところで\n何一つ理解できまい。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.相馬に裏切られたからでは\n\\.･･････ないのか。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "･･････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.知っているなら\n余計なことを聞くな。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "今なら見逃してやる。\nとっとと去れ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "待て。\n\\.そなたは誤解しているのだ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さん。\n聞いてやって欲しいニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "こ奴\n無愛想で 態度がでかくて\nさらに物覚えが悪いけど"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "オイラのこと助けてくれたし\n\\.悪い奴ではなさそうニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････$d\n私はそんな風に見えるのか？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.その 相馬という奴は\n姫さんの知り合いなんニャ？"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.タマ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "それ以上口を開けば\nそなたも斬るぞ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.っモゴ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.短気で人の話を聞かぬところは\n相馬そっくりだな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.似たもの同士が\n惹かれ合うというのは\n人にも狐にも当てはまるらしい。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.\\S[2]･････････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.どうしても\n相手になって欲しいようだな。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "よい、太刀を抜け！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.チョ、チョット待ってニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "････････････････････\n････････････････････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････あ、アレ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････闘うの\\.やめたのニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.そなた･･･\n\\.急に大願面になるな、タマ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "だから、\nタマじゃなくって～～～･･････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.\\S[5]････････････"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.アレ？\\.･･･タマニャ。\nあってるニャ。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.そなた･･････"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.ただの人間のくせに\nなぜ狐火を放つことが出来る？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.狐火？"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.いや、その前に･･･"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.なぜ、私と相馬春信のことを\n知っている？！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "　\\S[2]･････････。"
        },
        {
            "face": "Ｆ狐姫",
            "marker": "Message",
            "text": "\\.？！"
        },
