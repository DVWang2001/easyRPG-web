    ],
    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "おジジ、生きてるニャ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵も酒も持ったニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "おジジには悪いが\n勝手に鍵持ってくニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "えーと"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あったニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "はニャ？\n･･････コレはなにニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ほう、酒か。\n気付け薬代わりになるな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････\nもらってけと言っているように\n聞こえるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "ふむ。延命酒『剣豪』か。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "こんな酒を飲んでいたとは\nこの爺様の長生きなワケがわかるな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "聞いとらんニャ　お主･･･。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "ほっほっほ"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\S[2]やはり来たの　若者。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.やはり？"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\.さっき\n一つ目根を倒した様子を\n見ておったでの。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "いや、なかなかの腕前じゃ。\n人間にしておくのは惜しいの。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "おジジ。\nこ奴、姫さんに話がある\nだけなんだそうニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.だから\nそこを通してやって欲しいニャ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "それはできん。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "姫さんとの約束じゃ。\nここは決して誰も通さぬ　とな。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\.まして\n初対面の者の言う言葉を\nすぐさま 信用するわけにもいかぬ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "歳を取ると疑い深くての。\n\\.ま、悪く思うでない。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.いや、もっともな話だ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.だが、私を信じて\nその帰りを待っている者が\nいるのでな。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "すまぬが\nなんとしても、そこを通らねばならぬ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\S[2]お主の帰りを信じて･･････？"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\S[2]･････････"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\.\\.それは･･････お主の恋人かの？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.いや\n残念ながら 男だ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "･･････\n\\S[2]ほっほっほ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\.仕方ないの。\nでは、わしを倒してから行きなされ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\.もっとも\n\\.倒せればの話じゃがの。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "やめといた方がいいニャ　おジジ。\nまたぎっくり腰になるニャ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "ほっほっほ。\n人の心配をする前に\n自分の心配をするがよいぞ。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\S[2]･･････力を貸せ\n我と共に老いる枯れ木よ･･････！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.で、出た！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････カラスの次は \\.･･･枯れ木か。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "ほっほっほ。\n年寄りと思うて 手加減する必要はない。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "思いっきりかかってくるがよい。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.おっ、おジジ？！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.ニャっ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "わ～っ\nまたニャ～～～っ！！！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "鍵がないと開かないニャ。\nそこら辺に緑の包みがないニャ？"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "･･･では\n\\.私を信じて･･･待っていて下さる？"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "寂しいけど･･･\n私はいつまでも待っているよ、綾。"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "･･････ありがとう。"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "本当は私、行きたくはないわ。"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "でも、年をとっている父を\n１人で遠くの村まで行かせるのは\nどうしても不安なの。"
        },
        {
            "face": "Ｆお爺",
            "marker": "Message",
            "text": "\\.わかってる。"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "その辺りの村には\n他にお医者様は１人も\nいらっしゃらないんですって。"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "せめて\nその地で起こっている戦が\n早く終わってくれれば･･･"
        },
        {
            "face": "Ｆ綾",
            "marker": "Message",
            "text": "けが人や病人さえ減ってくれさえすれば\n\\.私も父も、すぐ\n帰って来られるはずだから･･･"
        },
