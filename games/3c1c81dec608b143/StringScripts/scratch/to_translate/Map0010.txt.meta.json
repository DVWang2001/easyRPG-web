        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.アレ？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さん、おらんニャ～。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "いつもだったらこの辺で\n\\.かったるそうに、こう\n脇息にもたれかかって"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "こんな風に\n\\.お尻をぽりぽり掻いてるんだけどニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.おらぬか･･････。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.では仕方ない。\n帰るとするか。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "あ、コラ、待つニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ここまで来て帰るとは\nなんニャ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "姫さんなら、\nきっと上におるニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]････････････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "　\\.？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なんか迷うとるんかいニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･････････"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.いや･･･。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なら、行くニャ。"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\C[17]\\S[2]はたして私がここへ来たのは"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\S[2]\\C[17]あの男のためなのか\n\\.それとも自分のためなのか･･･"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
            "text": "\\.\\S[2]\\C[17]本当はここへは\nやって来たくなかったのかもしれない"
        },
        {
            "face": "Erase }}}}}}}}}}}}}}}}}}}}",
            "marker": "Message",
