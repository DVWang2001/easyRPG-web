    "items": [
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "お花ニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "か～わいい～から\n摘んでくニャ～♪"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャっと"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "妖怪かもしれぬぞ。\nほれ、べよ～んという音と共に･･･"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ニャ？！　ニャ？！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "･･････おっ、おどかすニャっ！"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.\\S[2]･･････\n\\S[1]そなた、自分が妖怪だという意識が\n薄いな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ほ、ほっといてニャ！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "狭い通りニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "縦に並んで歩けば通れるだろう。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.お主先に行ってニャ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ゆ、ゆっくり歩いてニャ。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\S[2]･･････ん？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･････。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "何ニャ？"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "\\.･･･同行メンバーが\n１人増えているようなのだが。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.？？？"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.なんニャ？コレ。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ブニャ～～～～～～～～～～～～！！！"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "ふに。"
        },
        {
            "face": "F鞍春",
            "marker": "Message",
            "text": "そなた\n\\.挟まったり 絡まったり\n巻き付かれたり 忙しいな。"
        },
        {
            "face": "Ｆタマ",
            "marker": "Message",
            "text": "\\.･･････悪かったニャ。"
        }
    ]
}